# ============================================================
# Lamma — Environment Variables
# ============================================================
# Copy this file to `.env` for local dev, or set these in Railway
# Variables tab for production.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# LOCAL DEV: SQLite (file-based, no setup needed)
DATABASE_URL="file:./db/custom.db"

# PRODUCTION (Supabase PostgreSQL):
# 1. Use Transaction pooler (port 6543) with ?pgbouncer=true
# 2. Railway doesn't support IPv6, so direct connection (port 5432) fails
# 3. NEVER put $ in the password (use %24 instead, or avoid $ entirely)
#
# DATABASE_URL="postgresql://postgres.lamma:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.lamma:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# Next.js
# ------------------------------------------------------------
NODE_ENV="production"
NEXTAUTH_URL="https://your-app.up.railway.app"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# ------------------------------------------------------------
# AI (z-ai-web-dev-sdk)
# ------------------------------------------------------------
# Optional: if empty, AI features use deterministic mock fallbacks.
# Get from your z-ai dashboard.
ZAI_API_KEY=""

# ------------------------------------------------------------
# Clerk (Authentication) — Phase C
# ------------------------------------------------------------
# Optional: if empty, app falls back to mock auth (Zustand + localStorage).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
# CLERK_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# Supabase (Realtime + Storage) — Phase B/C
# ------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL="https://lamma.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# ------------------------------------------------------------
# Tap Payments (KNET) — Production only
# ------------------------------------------------------------
# TAP_SECRET_KEY="sk_live_..."
# TAP_PUBLIC_KEY="pk_live_..."

# ------------------------------------------------------------
# Mapbox — Optional (currently using SVG map)
# ------------------------------------------------------------
# NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoibGFtbWEiLC..."

# ------------------------------------------------------------
# Cloudinary (Image CDN) — Optional
# ------------------------------------------------------------
# CLOUDINARY_CLOUD_NAME="..."
# CLOUDINARY_API_KEY="..."
# CLOUDINARY_API_SECRET="..."

# ------------------------------------------------------------
# Resend (Email) — Optional
# ------------------------------------------------------------
# RESEND_API_KEY="re_..."
# EMAIL_FROM="hello@lamma.kw"

# ------------------------------------------------------------
# OpenAI (Real embeddings) — Optional (currently using TF-IDF)
# ------------------------------------------------------------
# OPENAI_API_KEY="sk-..."

# ------------------------------------------------------------
# Sentry (Error tracking) — Optional
# ------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN="https://..."
# SENTRY_DSN="https://..."

# ------------------------------------------------------------
# Live Companion (internal)
# ------------------------------------------------------------
LIVE_COMPANION_PORT=3003

# ------------------------------------------------------------
# Aladhan API (Prayer times) — No key needed (free public API)
# ------------------------------------------------------------
# Default city is Kuwait; no API key required.
