  "faq": {
    "title": "أسئلة شائعة",
    "subtitle": "ما يسأل عنه القادمون الجدد قبل أول لمة.",
    "categories": {
      "general": "عام",
      "application": "التقديم",
      "hosting": "الاستضافة",
      "payment": "الدفع",
      "conduct": "السلوك",
      "gatherings": "التجمعات والحضور",
      "hosts": "أصحاب التجمعات",
      "payments": "المدفوعات والإلغاء",
      "tech": "التقنية والخصوصية"
    },
    "q1": "ما هي لَمَّة؟",
    "a1": "لَمَّة منصّة كويتية لتجمعاتٍ حميمية مُنتقاة. كل لمةٍ تجمّعٌ صغير (٨–٥٠ شخصاً) يستضيفه شخصٌ يعرف ضيوفه، حول موضوعٍ تحريري محدّد.",
    "q2": "كيف أشارك في لمة؟",
    "a2": "اختر لمةً من قائمة اللمات، اقرأ وصفها، ثم قدّم طلبك عبر نموذج التقديم. صاحب اللمة يراجع الطلبات ويقبل من يراه مناسباً.",
    "q3": "هل لمة مجانية؟",
    "a3": "بعض اللمات مجانية، وبعضها مدفوع لتغطية تكاليف المواد أو المكان. السعر يُذكر بوضوح في صفحة كل لمة.",
    "q4": "ما حجم اللمة عادةً؟",
    "a4": "بين ٨ و٥٠ شخصاً، بحسب الموضوع. لا نتجاوز السقف أبداً — حتى لو طلب المئات.",
    "q5": "هل يجب أن أحضر بمفردي؟",
    "a5": "نعم، نوصي بذلك. اللمة فرصة لتعرف وجوهاً جديدة. إن أتيت مع صديق، تجلسان معاً لكنّكما تلتقيان بالآخرين.",
    "q6": "كم يستغرق التقديم؟",
    "a6": "نموذج قصير: دافعك للحضور، وإجابةٌ على سؤالٍ أو سؤالين من صاحب اللمة. ٥ دقائق عادةً.",
    "q7": "متى أعرف نتيجة التقديم؟",
    "a7": "خلال ٣–٧ أيام عادةً. تصلك رسالة بقبولٍ أو رفضٍ أو قائمة انتظار.",
    "q8": "هل يمكنني إلغاء طلبي؟",
    "a8": "نعم، من لوحتك. لكن نرجو عدم الإلغاء بعد القبول إلا لظرفٍ طارئ — المكان محجوز لك.",
    "q9": "ماذا لو رُفض طلبي؟",
    "a9": "الرفض ليس شخصياً. صاحب اللمة يختار من يراه الأنسب للموضوع. جرّب لمةً أخرى — هناك لماتٌ كثيرة.",
    "q10": "كيف أصبح صاحب لمة؟",
    "a10": "سجّل كصاحب لمة من حسابك، ثم أنشئ لمتك الأولى. ستراجعها لَمَّة قبل النشر.",
    "q11": "ما الذي يُتوقّع من صاحب اللمة؟",
    "a11": "أن يستقبل ضيوفه بالاسم، أن يحترم مواعيد الصلاة، أن يكتب وصفاً صادقاً، وأن يراجع الطلبات بنيةٍ حسنة.",
    "q12": "هل آخذ مالاً مقابل الاستضافة؟",
    "a12": "إن كانت لمتك مدفوعة، يذهب الجزء الأكبر لتكاليف المواد. لَمَّة تأخذ عمولةً صغيرة لتغطية تشغيل المنصّة.",
    "q13": "هل يمكنني استضافة لمة في بيتي؟",
    "a13": "نعم. حدّد ذلك في نموذج إنشاء اللمة، وسيُطلب من الضيوف احترام خصوصية المكان.",
    "q14": "كيف أدفع؟",
    "a14": "بعد قبول طلبك، يُطلب منك الدفع إلكترونياً عبر بطاقةٍ مدعومة. لا نقبل الدفع نقداً في الموقع.",
    "q15": "هل يمكن استرداد المبلغ؟",
    "a15": "خلال ٤٨ ساعة من الدفع، نعم. بعد ذلك، فقط قبل ٧٢ ساعةٍ من موعد اللمة، ولظرفٍ طارئ.",
    "q16": "هل تُصدر فواتير؟",
    "a16": "نعم، تُرسل الفاتورة إلى بريدك إلكترونياً بعد الدفع.",
    "q17": "ما ميثاق السلوك؟",
    "a17": "نلتزم بآداب الحوار: لا مقاطعة، لا تصعيد، لا تداول أموالٍ أو بطاقاتٍ في اللمة. اللمة للحوار، لا للتجارة.",
    "q18": "ماذا يحدث لو خالف أحدٌ الميثاق؟",
    "a18": "صاحب اللمة يحقّ له إنهاء اللمة. لَمَّة قد تمنع المخالف من الحضور مستقبلاً.",
    "q19": "هل اللمة مناسبة لجميع الأعمار؟",
    "a19": "بعض اللمات عائلية (مثل لمات الأبراج)، وبعضها للبالغين فقط. يُذكر ذلك بوضوح في صفحة كل لمة.",
    "q20": "كيف أتواصل معكم؟",
    "a20": "عبر hello@lamma.kw أو رسالة مباشرة على إنستغرام @lamma.kw. نردّ خلال ٤٨ ساعة.",
